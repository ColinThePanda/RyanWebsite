---
import Layout from "@/layouts/Layout.astro";
import WritingPage from "@/components/WritingPage.astro";
import { getStaticTextPaths, type TextEntry } from "@/lib/writings";

export function getStaticPaths() {
  return getStaticTextPaths("artist-statements");
}

const { entry } = Astro.props as { entry: TextEntry };
---

<Layout title={entry.title}>
  <WritingPage entry={entry} />
</Layout>
