---
import Layout from "@/layouts/Layout.astro";
import { withBase } from "@/lib/base";
---

<Layout title="Home">
  <main class="min-h-screen bg-black text-white px-10 pt-8 p-0">
    <div class="max-w-3xl p-0">
      <!-- Main categories -->
      <div class="text-6xl md:text-8xl leading-tight font-serif space-y-3 p-0">
        <a
          href={withBase("/poems")}
          class="block text-blue-500 hover:text-blue-400 transition"
        >
          poems
        </a>

        <div class="pl-16">
          <a
            href={withBase("/essays")}
            class="block text-red-500 hover:text-red-400 transition"
          >
            essays
          </a>

          <div class="pl-16">
            <a
              href={withBase("/notes")}
              class="block text-gray-300 hover:text-gray-100 transition"
            >
              notes
            </a>
          </div>
        </div>
      </div>

      <div class="mt-12 pl-2">
        <a
          href={withBase("/more")}
          class="text-2xl md:text-3xl text-purple-400 hover:text-purple-300 transition font-serif"
        >
          more
        </a>
      </div>
    </div>
  </main>
</Layout>
