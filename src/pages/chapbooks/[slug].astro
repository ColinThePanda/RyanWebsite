---
import Layout from "@/layouts/Layout.astro";
import { withBase } from "@/lib/base";
import { getStaticChapbookWarningPaths, type ChapbookEntry } from "@/lib/chapbooks";

export function getStaticPaths() {
  return getStaticChapbookWarningPaths();
}

const { entry } = Astro.props as { entry: ChapbookEntry };
---

<Layout title={entry.title}>
  <section class="px-4 pt-8 sm:px-10">
    <div class="w-full max-w-4xl">
      <h1 class="font-serif text-5xl leading-tight text-white sm:text-6xl">
        Are you sure you want to read {entry.title}?
      </h1>

      <div class="mt-8 border border-zinc-800 px-5 py-5 sm:px-6">
        <p class="font-serif text-xl leading-relaxed text-zinc-300">
          <span class="text-white">Content Warning:</span> {entry.contentWarning}
        </p>

        <div class="mt-8 flex gap-4 font-serif text-2xl">
          <a
            href={entry.pdfUrl}
            class="border border-zinc-700 px-6 py-3 text-white transition hover:border-zinc-500 hover:text-zinc-200"
          >
            yes
          </a>
          <a
            href={withBase("/chapbooks")}
            class="border border-zinc-800 px-6 py-3 text-zinc-400 transition hover:border-zinc-600 hover:text-zinc-200"
          >
            no
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
