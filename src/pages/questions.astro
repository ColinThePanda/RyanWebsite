---
import StyledTitle from "@/components/StyledTitle.astro";
import questionsData from "@/content/questions.json";
import Layout from "@/layouts/Layout.astro";
import { getQuestionRecords, type QuestionEntry } from "@/lib/questions";

const questions = getQuestionRecords(questionsData as QuestionEntry[]);
const titleSegments = [
  { text: "\u00bf", className: "text-red-500" },
  { text: "s" },
];
---

<Layout title="questions">
  <section class="px-4 pt-8 sm:px-10">
    <div class="w-full">
      <h1 class="text-6xl leading-tight font-serif">
        <StyledTitle segments={titleSegments} />
      </h1>

      {
        questions.length > 0 ? (
          <div class="mt-10 space-y-8">
            {questions.map((entry) => (
              <article class="grid grid-cols-[9.5rem_1fr] gap-x-6 font-serif sm:grid-cols-[11.5rem_1fr]">
                <time datetime={entry.isoAskedAt} class="pt-0.5 text-white/55">
                  <span class="block text-lg leading-tight sm:text-xl">{entry.dateLabel}</span>
                  <span class="mt-1 block text-lg leading-tight sm:text-xl">{entry.timeLabel}</span>
                </time>

                <div>
                  <h2 class="text-2xl leading-tight text-white">{entry.question}</h2>
                  <p class="mt-3 max-w-4xl whitespace-pre-line text-xl leading-relaxed text-zinc-300">
                    {entry.answer}
                  </p>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p class="mt-10 text-zinc-500">nothing here yet</p>
        )
      }
    </div>
  </section>
</Layout>
