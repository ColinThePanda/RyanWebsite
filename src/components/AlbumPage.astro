---
import type { AlbumEntry } from "@/lib/media";

interface Props {
  album: AlbumEntry;
}

const { album } = Astro.props as Props;
---

<section class="px-4 pt-8 sm:px-10">
  <div class="w-full">
    <header>
      <p class="text-xl font-serif text-white/55">{album.date}</p>
      <h1 class="mt-2 font-serif text-6xl leading-tight text-white">
        {album.title}
      </h1>
    </header>

    <div class="mt-10 space-y-8">
      {
        album.tracks.map((track, index) => (
          <div class="grid grid-cols-[8rem_1fr] gap-x-6 text-2xl font-serif leading-tight sm:grid-cols-[9rem_1fr]">
            <div class="text-white/55">{track.date}</div>
            <div>
              <a href={track.url} class="text-white transition hover:text-zinc-300">
                {track.title}
              </a>
              <span
                class="ml-6 text-white/55"
                data-audio-duration
                data-audio-url={track.assetUrl}
                data-audio-id={`album-track-${index}`}
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const formatDuration = (seconds) => {
    if (!Number.isFinite(seconds) || seconds <= 0) return "";

    const rounded = Math.round(seconds);
    const hours = Math.floor(rounded / 3600);
    const minutes = Math.floor((rounded % 3600) / 60);
    const secs = rounded % 60;

    if (hours > 0) {
      return `${hours}:${String(minutes).padStart(2, "0")}:${String(secs).padStart(2, "0")}`;
    }

    return `${minutes}:${String(secs).padStart(2, "0")}`;
  };

  const durationNodes = document.querySelectorAll("[data-audio-duration]");
  const durationCache = new Map();

  for (const node of durationNodes) {
    const url = node.getAttribute("data-audio-url");

    if (!url) continue;

    if (durationCache.has(url)) {
      node.textContent = durationCache.get(url);
      continue;
    }

    const audio = document.createElement("audio");
    audio.preload = "metadata";
    audio.src = url;

    const applyDuration = () => {
      const text = formatDuration(audio.duration);
      durationCache.set(url, text);
      node.textContent = text;
    };

    audio.addEventListener("loadedmetadata", applyDuration, { once: true });
    audio.addEventListener(
      "error",
      () => {
        durationCache.set(url, "");
      },
      { once: true },
    );
  }
</script>
