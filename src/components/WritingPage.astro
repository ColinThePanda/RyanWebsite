---
import { type TextEntry } from "@/lib/writings";

interface Props {
  entry: TextEntry;
}

const { entry } = Astro.props;
---

<section class="px-4 pt-8 sm:px-10">
  <div class="w-full">
    <header>
      {entry.date && <p class="text-xl font-serif text-white/55">{entry.date}</p>}
      <h1 class="mt-2 font-serif text-6xl leading-tight text-white">
        {entry.title}
      </h1>
    </header>

    <article class="mt-10 whitespace-pre-wrap font-serif text-[1.6rem] leading-[2.5rem] text-white">
      {entry.body}
    </article>
  </div>
</section>
