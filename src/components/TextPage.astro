---
interface Props {
  title: string;
  file: string;
}

const { title, file } = Astro.props;

const modules = import.meta.glob("../content/**/*.txt", {
  as: "raw",
  eager: true,
});

const content = modules[file] as string;
---

<section class="mx-auto max-w-2xl px-6 py-12">
  <header class="mb-8">
    <h1 class="text-2xl font-semibold tracking-tight">
      {title}
    </h1>
  </header>

  <article
    class="space-y-6 leading-relaxed text-foreground/90 whitespace-pre-wrap"
  >
    {content}
  </article>
</section>
